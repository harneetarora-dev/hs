generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  owner
  merchant
  supervisor
  designer
  contractor
}

enum LeadSource {
  phone
  email
  walk_in
  architect_referral
  other
}

enum LeadStatus {
  new
  contacted
  qualified
  converted
  lost
}

enum QuoteStatus {
  draft
  sent
  approved
  revision_requested
  lost
}

enum DiscountType {
  none
  percentage
  fixed
}

enum MaterialCategory {
  wood
  hardware
  fabric
  glass
  metal
  finish
  other
}

enum MeasurementUnit {
  mm
  cm
  inch
  ft
}

enum QuantityUnit {
  sq_ft
  cu_ft
  running_ft
  piece
  kg
  litre
  set
}

enum AdvanceStatus {
  requested
  partial
  received
}

enum OrderStatus {
  pending_advance
  confirmed
  in_production
  quality_check
  dispatched
  delivered
  closed
  cancelled
}

enum OrderItemStatus {
  pending
  in_production
  complete
  dispatched
}

enum AssignmentStatus {
  assigned
  in_progress
  quality_check
  complete
}

enum DesignRequestUrgency {
  normal
  urgent
}

enum DesignRequestStatus {
  pending
  in_progress
  completed
  revision_requested
}

enum InvoiceStatus {
  generated
  sent
  partial
  paid
  overdue
}

enum FileTag {
  reference
  client_approved
  working_drawing
  as_built
  progress_photo
  delivery_proof
}

enum EntityType {
  lead
  quote
  order
  production
}

model User {
  id                   String   @id @default(uuid())
  name                 String
  email                String   @unique
  passwordHash         String   @map("password_hash")
  role                 Role
  phone                String?
  skills               Json?
  maxConcurrentOrders  Int?     @map("max_concurrent_orders")
  isActive             Boolean  @default(true) @map("is_active")
  createdAt            DateTime @default(now()) @map("created_at")

  leads                Lead[]
  quotes               Quote[]
  orders               Order[]
  ordersSupervisor     Order[]            @relation("SupervisorOrders")
  orderAssignments     OrderAssignment[]  @relation("ContractorAssignments")
  assignedBy           OrderAssignment[]  @relation("AssignedByUser")
  productionLogs       ProductionLog[]
  delayLogs            DelayLog[]
  designRequestsBy     DesignRequest[]    @relation("RequestedBy")
  designRequestsFor    DesignRequest[]    @relation("AssignedTo")
  quoteVersions        QuoteVersion[]     @relation("CreatedBy")
  quoteVersionsApproved QuoteVersion[]    @relation("ApprovedBy")
  invoices             Invoice[]
  payments             Payment[]
  files                File[]
  auditLogs            AuditLog[]
  orderItems           OrderItem[]

  @@map("users")
}

model Architect {
  id              String   @id @default(uuid())
  name            String
  firmName        String?  @map("firm_name")
  phone           String?
  email           String?
  address         String?
  notes           String?
  totalReferrals  Int      @default(0) @map("total_referrals")
  totalConverted  Int      @default(0) @map("total_converted")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")

  leads           Lead[]

  @@map("architects")
}

model Lead {
  id              String     @id @default(uuid())
  leadNumber      String     @unique @map("lead_number")
  merchantId      String     @map("merchant_id")
  clientName      String     @map("client_name")
  clientPhone     String?    @map("client_phone")
  clientEmail     String?    @map("client_email")
  source          LeadSource
  architectId     String?    @map("architect_id")
  productInterest String?    @map("product_interest")
  notes           String?
  status          LeadStatus @default(new)
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  merchant        User       @relation(fields: [merchantId], references: [id])
  architect       Architect? @relation(fields: [architectId], references: [id])
  quotes          Quote[]

  @@map("leads")
}

model Quote {
  id             String       @id @default(uuid())
  quoteNumber    String       @unique @map("quote_number")
  leadId         String       @map("lead_id")
  merchantId     String       @map("merchant_id")
  currentVersion Int          @default(1) @map("current_version")
  status         QuoteStatus  @default(draft)
  taxRate        Decimal      @default(18.00) @map("tax_rate") @db.Decimal(5, 2)
  discountType   DiscountType @default(none) @map("discount_type")
  discountValue  Decimal      @default(0) @map("discount_value") @db.Decimal(12, 2)
  notesToClient  String?      @map("notes_to_client")
  internalNotes  String?      @map("internal_notes")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  lead           Lead         @relation(fields: [leadId], references: [id])
  merchant       User         @relation(fields: [merchantId], references: [id])
  versions       QuoteVersion[]
  bomItems       BomItem[]
  orders         Order[]

  @@map("quotes")
}

model QuoteVersion {
  id            String   @id @default(uuid())
  quoteId       String   @map("quote_id")
  versionNumber Int      @map("version_number")
  changeSummary String?  @map("change_summary")
  changeReason  String?  @map("change_reason")
  createdById   String   @map("created_by")
  approvedById  String?  @map("approved_by")
  snapshotData  Json     @map("snapshot_data")
  createdAt     DateTime @default(now()) @map("created_at")

  quote         Quote    @relation(fields: [quoteId], references: [id])
  createdBy     User     @relation("CreatedBy", fields: [createdById], references: [id])
  approvedBy    User?    @relation("ApprovedBy", fields: [approvedById], references: [id])

  @@map("quote_versions")
}

model BomItem {
  id               String           @id @default(uuid())
  quoteId          String           @map("quote_id")
  lineNumber       Int              @map("line_number")
  description      String
  materialCategory MaterialCategory @map("material_category")
  materialName     String?          @map("material_name")
  materialGrade    String?          @map("material_grade")
  supplier         String?
  unit             QuantityUnit
  quantity         Decimal          @db.Decimal(10, 2)
  ratePerUnit      Decimal          @map("rate_per_unit") @db.Decimal(12, 2)
  materialCost     Decimal          @map("material_cost") @db.Decimal(12, 2)
  laborCost        Decimal          @default(0) @map("labor_cost") @db.Decimal(12, 2)
  finishingCost    Decimal          @default(0) @map("finishing_cost") @db.Decimal(12, 2)
  hardwareCost     Decimal          @default(0) @map("hardware_cost") @db.Decimal(12, 2)
  transportCost    Decimal          @default(0) @map("transport_cost") @db.Decimal(12, 2)
  marginPercent    Decimal          @default(0) @map("margin_percent") @db.Decimal(5, 2)
  lineTotal        Decimal          @map("line_total") @db.Decimal(12, 2)
  lengthValue      Decimal?         @map("length_value") @db.Decimal(10, 2)
  lengthUnit       MeasurementUnit? @map("length_unit")
  widthValue       Decimal?         @map("width_value") @db.Decimal(10, 2)
  widthUnit        MeasurementUnit? @map("width_unit")
  heightValue      Decimal?         @map("height_value") @db.Decimal(10, 2)
  heightUnit       MeasurementUnit? @map("height_unit")
  depthValue       Decimal?         @map("depth_value") @db.Decimal(10, 2)
  depthUnit        MeasurementUnit? @map("depth_unit")
  customDimensions Json?            @map("custom_dimensions")
  dimensionNotes   String?          @map("dimension_notes")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  quote            Quote            @relation(fields: [quoteId], references: [id])

  @@map("bom_items")
}

model Order {
  id                     String        @id @default(uuid())
  orderNumber            String        @unique @map("order_number")
  quoteId                String        @map("quote_id")
  quoteVersion           Int           @map("quote_version")
  merchantId             String        @map("merchant_id")
  clientName             String        @map("client_name")
  clientPhone            String?       @map("client_phone")
  clientEmail            String?       @map("client_email")
  advanceAmount          Decimal?      @map("advance_amount") @db.Decimal(12, 2)
  advanceStatus          AdvanceStatus? @map("advance_status")
  advanceReceivedDate    DateTime?     @map("advance_received_date")
  advancePaymentMethod   String?       @map("advance_payment_method")
  supervisorId           String?       @map("supervisor_id")
  supervisorAssignedDate DateTime?     @map("supervisor_assigned_date")
  status                 OrderStatus   @default(pending_advance)
  expectedCompletionDate DateTime?     @map("expected_completion_date")
  actualCompletionDate   DateTime?     @map("actual_completion_date")
  notes                  String?
  createdAt              DateTime      @default(now()) @map("created_at")
  updatedAt              DateTime      @updatedAt @map("updated_at")

  quote                  Quote         @relation(fields: [quoteId], references: [id])
  merchant               User          @relation(fields: [merchantId], references: [id])
  supervisor             User?         @relation("SupervisorOrders", fields: [supervisorId], references: [id])
  orderItems             OrderItem[]
  assignments            OrderAssignment[]
  productionLogs         ProductionLog[]
  delayLogs              DelayLog[]
  invoices               Invoice[]

  @@map("orders")
}

model OrderItem {
  id                     String          @id @default(uuid())
  orderId                String          @map("order_id")
  itemNumber             Int             @map("item_number")
  description            String
  quantity               Int             @default(1)
  bomReference           String?         @map("bom_reference")
  status                 OrderItemStatus @default(pending)
  contractorId           String?         @map("contractor_id")
  locationId             String?         @map("location_id")
  expectedCompletionDate DateTime?       @map("expected_completion_date")
  actualCompletionDate   DateTime?       @map("actual_completion_date")
  notes                  String?
  createdAt              DateTime        @default(now()) @map("created_at")
  updatedAt              DateTime        @updatedAt @map("updated_at")

  order                  Order           @relation(fields: [orderId], references: [id])
  contractor             User?           @relation(fields: [contractorId], references: [id])
  location               Location?       @relation(fields: [locationId], references: [id])

  @@map("order_items")
}

model OrderAssignment {
  id              String           @id @default(uuid())
  orderId         String           @map("order_id")
  contractorId    String           @map("contractor_id")
  locationId      String?          @map("location_id")
  assignedById    String           @map("assigned_by")
  startDate       DateTime?        @map("start_date")
  expectedEndDate DateTime?        @map("expected_end_date")
  actualEndDate   DateTime?        @map("actual_end_date")
  status          AssignmentStatus @default(assigned)
  notes           String?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")

  order           Order            @relation(fields: [orderId], references: [id])
  contractor      User             @relation("ContractorAssignments", fields: [contractorId], references: [id])
  location        Location?        @relation(fields: [locationId], references: [id])
  assignedBy      User             @relation("AssignedByUser", fields: [assignedById], references: [id])

  @@map("order_assignments")
}

model ProductionLog {
  id        String   @id @default(uuid())
  orderId   String   @map("order_id")
  loggedBy  String   @map("logged_by")
  status    String
  notes     String?
  createdAt DateTime @default(now()) @map("created_at")

  order     Order    @relation(fields: [orderId], references: [id])
  user      User     @relation(fields: [loggedBy], references: [id])

  @@map("production_logs")
}

model DelayLog {
  id           String   @id @default(uuid())
  orderId      String   @map("order_id")
  loggedBy     String   @map("logged_by")
  reason       String
  originalDate DateTime @map("original_date")
  revisedDate  DateTime @map("revised_date")
  createdAt    DateTime @default(now()) @map("created_at")

  order        Order    @relation(fields: [orderId], references: [id])
  user         User     @relation(fields: [loggedBy], references: [id])

  @@map("delay_logs")
}

model DesignRequest {
  id             String              @id @default(uuid())
  requestNumber  String              @unique @map("request_number")
  entityType     EntityType          @map("entity_type")
  entityId       String              @map("entity_id")
  requestedById  String              @map("requested_by")
  assignedToId   String?             @map("assigned_to")
  title          String
  description    String?
  urgency        DesignRequestUrgency @default(normal)
  status         DesignRequestStatus  @default(pending)
  revisionOf     String?             @map("revision_of")
  revisionNotes  String?             @map("revision_notes")
  completedAt    DateTime?           @map("completed_at")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  requestedBy    User                @relation("RequestedBy", fields: [requestedById], references: [id])
  assignedTo     User?               @relation("AssignedTo", fields: [assignedToId], references: [id])

  @@map("design_requests")
}

model Location {
  id        String   @id @default(uuid())
  name      String
  address   String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  orderItems       OrderItem[]
  orderAssignments OrderAssignment[]

  @@map("locations")
}

model Invoice {
  id              String        @id @default(uuid())
  invoiceNumber   String        @unique @map("invoice_number")
  orderId         String        @map("order_id")
  merchantId      String        @map("merchant_id")
  subtotal        Decimal       @db.Decimal(12, 2)
  gstRate         Decimal       @default(18.00) @map("gst_rate") @db.Decimal(5, 2)
  gstAmount       Decimal       @map("gst_amount") @db.Decimal(12, 2)
  advanceDeducted Decimal       @default(0) @map("advance_deducted") @db.Decimal(12, 2)
  discount        Decimal       @default(0) @db.Decimal(12, 2)
  totalDue        Decimal       @map("total_due") @db.Decimal(12, 2)
  paymentDueDate  DateTime?     @map("payment_due_date")
  status          InvoiceStatus @default(generated)
  notes           String?
  createdAt       DateTime      @default(now()) @map("created_at")

  order           Order         @relation(fields: [orderId], references: [id])
  merchant        User          @relation(fields: [merchantId], references: [id])
  payments        Payment[]

  @@map("invoices")
}

model Payment {
  id              String   @id @default(uuid())
  invoiceId       String   @map("invoice_id")
  amount          Decimal  @db.Decimal(12, 2)
  paymentMethod   String?  @map("payment_method")
  paymentDate     DateTime @map("payment_date")
  referenceNumber String?  @map("reference_number")
  notes           String?
  recordedById    String   @map("recorded_by")
  createdAt       DateTime @default(now()) @map("created_at")

  invoice         Invoice  @relation(fields: [invoiceId], references: [id])
  recordedBy      User     @relation(fields: [recordedById], references: [id])

  @@map("payments")
}

model File {
  id             String     @id @default(uuid())
  entityType     EntityType @map("entity_type")
  entityId       String     @map("entity_id")
  fileName       String     @map("file_name")
  filePath       String     @map("file_path")
  fileSize       Int        @map("file_size")
  mimeType       String?    @map("mime_type")
  tag            FileTag?
  version        Int        @default(1)
  replacesFileId String?    @map("replaces_file_id")
  uploadedById   String     @map("uploaded_by")
  createdAt      DateTime   @default(now()) @map("created_at")

  uploadedBy     User       @relation(fields: [uploadedById], references: [id])

  @@map("files")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  action     String
  details    Json?
  createdAt  DateTime @default(now()) @map("created_at")

  user       User     @relation(fields: [userId], references: [id])

  @@map("audit_log")
}
